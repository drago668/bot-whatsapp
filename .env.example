# ─── Anthropic ───────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── WhatsApp / Meta ─────────────────────────────────────────
# Obtén estos valores en: https://developers.facebook.com
WHATSAPP_TOKEN=tu_whatsapp_token
WHATSAPP_PHONE_NUMBER_ID=tu_phone_number_id
WHATSAPP_VERIFY_TOKEN=un_string_secreto_que_tu_eliges   # Lo usas al configurar el webhook en Meta

# ─── Google (Gmail + Calendar) ───────────────────────────────
# Descarga credentials.json desde Google Cloud Console
# y colócalo en la raíz del proyecto
GOOGLE_CREDENTIALS_FILE=credentials.json
GOOGLE_TOKEN_FILE=token.json

# ─── App ─────────────────────────────────────────────────────
ALLOWED_PHONE_NUMBER=+57300000000   # Tu número de WhatsApp (solo tú podrás usar el bot)
